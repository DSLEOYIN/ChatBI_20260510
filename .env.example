# ChatBI local environment template
# Copy values into .env for local development. Do not commit real secrets.

# Backend
CHATBI_DB_PATH=./chatbi_mock.db
CHATBI_DATA_ASSETS_PATH=./server/config/data_assets.json

# Dify knowledge base
CHATBI_DIFY_ENABLED=false
DIFY_API_BASE_URL=http://10.30.11.215:9879
DIFY_API_KEY=
DIFY_RERANKING_PROVIDER=langgenius/siliconflow/siliconflow
DIFY_RERANKING_MODEL=netease-youdao/bce-reranker-base_v1
DIFY_EMBEDDING_PROVIDER=langgenius/siliconflow/siliconflow
DIFY_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Query provider: mock | mysql
CHATBI_QUERY_PROVIDER=mock

# MySQL direct connection, or the remote MySQL address reachable from SSH host.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_CONNECT_TIMEOUT=15

# Optional SSH tunnel for MySQL. Fill either password or private key.
MYSQL_SSH_ENABLED=false
MYSQL_SSH_HOST=
MYSQL_SSH_PORT=22
MYSQL_SSH_USER=
MYSQL_SSH_PASSWORD=
MYSQL_SSH_PRIVATE_KEY_PATH=
MYSQL_SSH_PRIVATE_KEY_PASSPHRASE=
MYSQL_SSH_LOCAL_PORT=0

# Tavily, reserved for the search adapter step
TAVILY_API_KEY=
